# === Frontend (Next.js) ===
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXTAUTH_SECRET=your-nextauth-secret-change-this
NEXTAUTH_URL=http://localhost:3000

# === Backend (FastAPI) ===
# LM Studio
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=qwen3-8b

# Telegram (알림 전용)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Chrome CDP 포트
CHROME_GOOGLE_PORT=9222
CHROME_META_PORT=9223
CHROME_GENERAL_PORT=9224

# Chrome 프로필 경로
CHROME_PROFILE_GOOGLE=~/chrome-profiles/google
CHROME_PROFILE_META=~/chrome-profiles/meta
CHROME_PROFILE_GENERAL=~/chrome-profiles/general

# CORS
CORS_ORIGINS=http://localhost:3000

