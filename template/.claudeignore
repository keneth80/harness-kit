# ============================================================================
# .claudeignore — Claude Code가 컨텍스트에 로드하지 않을 파일/디렉토리
#
# .gitignore와 다른 목적:
#   .gitignore   = Git에 커밋하지 않을 파일
#   .claudeignore = Claude Code가 읽지 않을 파일 (토큰 절약)
#
# 큰 파일, 바이너리, 자동 생성 파일을 제외하면
# 컨텍스트 윈도우를 효율적으로 사용할 수 있습니다.
# ============================================================================

# ── Dependencies (수천 개 파일, 읽을 필요 없음) ────
node_modules/
.pnp/
.venv/
venv/

# ── Build 결과물 ────────────────────────────────
.next/
out/
dist/
build/
__pycache__/

# ── Lock 파일 (거대하고 사람이 읽을 필요 없음) ──
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock

# ── 바이너리 / 미디어 ──────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.woff
*.woff2
*.ttf
*.eot
*.mp4
*.mp3
*.pdf

# ── 환경 설정 (시크릿 보호) ────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Chrome 프로필 (거대, 바이너리) ──────────────
chrome-profiles/

# ── DB 파일 ─────────────────────────────────────
*.db
*.sqlite
*.sqlite3
data/

# ── 테스트 결과물 ──────────────────────────────
coverage/
htmlcov/
test-results/
playwright-report/
blob-report/
.pytest_cache/
.nyc_output/

# ── 검증 리포트 (HTML, 브라우저로 확인) ────────
.claude/reports/*.html

# ── Supabase 로컬 데이터 ──────────────────────
supabase/.branches/
supabase/.temp/

# ── 로그 ────────────────────────────────────────
*.log
npm-debug.log*

# ── IDE 설정 ────────────────────────────────────
.vscode/
.idea/

# ── OS ──────────────────────────────────────────
.DS_Store
Thumbs.db
